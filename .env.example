# Modo confidencial — obrigatório para dados de clientes (bloqueia OpenAI)
CONFIDENTIAL_MODE=true

# Ollama (único backend em modo confidencial)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Modelos Ollama por módulo — criar com: ollama create <nome> -f modelfiles/<ficheiro>
OLLAMA_MODEL_CHAT=datamind-chat
OLLAMA_MODEL_DICTIONARY=datamind-dictionary
OLLAMA_MODEL_SQL=datamind-sql
OLLAMA_MODEL_BUSINESS_RULES=datamind-business-rules
OLLAMA_MODEL_KPI=datamind-kpi
OLLAMA_MODEL_RELATIONSHIPS=datamind-consulting
OLLAMA_MODEL_QUALITY=datamind-consulting

# Backend: em modo confidencial, apenas ollama é permitido
LLM_BACKEND=ollama

# Limites de desempenho
LARGE_DATASET_ROWS=100000
LLM_SAMPLE_ROWS=500

# OpenAI — desativado em modo confidencial (não necessário)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
